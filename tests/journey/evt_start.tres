[gd_resource type="Resource" script_class="JourneyEvent" format=3 uid="uid://b1evstartev01"]

[ext_resource type="Script" uid="uid://cd45ite7r06rf" path="res://addons/journey_engine_core/journey_event.gd" id="1_event"]
[ext_resource type="Script" uid="uid://bsf1m3b2h1ukg" path="res://addons/journey_engine_core/journey_choice.gd" id="2_choice"]
[ext_resource type="Script" uid="uid://i001tv2xcpdh" path="res://addons/journey_engine_core/journey_consequence.gd" id="3_conseq"]

[sub_resource type="Resource" id="Conseq_addgold"]
script = ExtResource("3_conseq")
key = "gold"
value = 50.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Choice_takegold"]
script = ExtResource("2_choice")
button_text = "Take the gold and travel on"
consequences = Array[ExtResource("3_conseq")]([SubResource("Conseq_addgold")])
continue_to_pool = true
pool_tags_filter = Array[String](["road"])
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[sub_resource type="Resource" id="Conseq_sethelped"]
script = ExtResource("3_conseq")
operation = 3
key = "helped_stranger"
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Choice_helpstranger"]
script = ExtResource("2_choice")
button_text = "Help the stranger"
consequences = Array[ExtResource("3_conseq")]([SubResource("Conseq_sethelped")])
target_event_id = &"evt_kind"
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[resource]
script = ExtResource("1_event")
narrative_text = "You reach a crossroads."
id = &"evt_start"
choices = Array[ExtResource("2_choice")]([SubResource("Choice_takegold"), SubResource("Choice_helpstranger")])
metadata/_custom_type_script = "uid://cd45ite7r06rf"
