[gd_resource type="Resource" script_class="JourneyEvent" format=3 uid="uid://jfet4pks6i5q"]

[ext_resource type="Script" uid="uid://cd45ite7r06rf" path="res://addons/journey_engine_core/journey_event.gd" id="1_event"]
[ext_resource type="Script" uid="uid://bsf1m3b2h1ukg" path="res://addons/journey_engine_core/journey_choice.gd" id="2_choice"]
[ext_resource type="Script" uid="uid://i001tv2xcpdh" path="res://addons/journey_engine_core/journey_consequence.gd" id="2_fophr"]
[ext_resource type="Script" uid="uid://k60namdri10y" path="res://addons/journey_engine_core/journey_condition.gd" id="3_cond"]
[ext_resource type="Script" uid="uid://bwkdyqkiuostq" path="res://addons/journey_engine_core/journey_condition_group.gd" id="4_group"]

[sub_resource type="Resource" id="Cond_heroic_sanity"]
script = ExtResource("3_cond")
key = "sanity"
value = 60.0
metadata/_custom_type_script = "uid://k60namdri10y"

[sub_resource type="Resource" id="Cond_heroic_flag"]
script = ExtResource("3_cond")
key = "helped_stranger"
op = 6
metadata/_custom_type_script = "uid://k60namdri10y"

[sub_resource type="Resource" id="Group_heroic_all"]
script = ExtResource("4_group")
conditions = Array[ExtResource("3_cond")]([SubResource("Cond_heroic_sanity"), SubResource("Cond_heroic_flag")])
metadata/_custom_type_script = "uid://bwkdyqkiuostq"

[sub_resource type="Resource" id="Choice_router_heroic"]
script = ExtResource("2_choice")
button_text = "Step into the dawn — wiser, kinder."
visibility = SubResource("Group_heroic_all")
target_event_id = &"evt_end_heroic"
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[sub_resource type="Resource" id="Cond_tragic_sanity"]
script = ExtResource("3_cond")
key = "sanity"
op = 3
value = 20.0
metadata/_custom_type_script = "uid://k60namdri10y"

[sub_resource type="Resource" id="Cond_tragic_gold"]
script = ExtResource("3_cond")
key = "gold"
op = 3
value = 10.0
metadata/_custom_type_script = "uid://k60namdri10y"

[sub_resource type="Resource" id="Group_tragic_any"]
script = ExtResource("4_group")
logic = 1
conditions = Array[ExtResource("3_cond")]([SubResource("Cond_tragic_sanity"), SubResource("Cond_tragic_gold")])
metadata/_custom_type_script = "uid://bwkdyqkiuostq"

[sub_resource type="Resource" id="Choice_router_tragic"]
script = ExtResource("2_choice")
button_text = "Stumble in — broken, broke, or both."
visibility = SubResource("Group_tragic_any")
target_event_id = &"evt_end_tragic"
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[sub_resource type="Resource" id="Choice_router_pragmatic"]
script = ExtResource("2_choice")
button_text = "Walk in. Settle the bill. Sleep."
target_event_id = &"evt_end_pragmatic"
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[resource]
script = ExtResource("1_event")
narrative_text = "The gates of the old city open. How you arrive matters now."
id = &"evt_ending_router"
choices = Array[ExtResource("2_choice")]([SubResource("Choice_router_heroic"), SubResource("Choice_router_tragic"), SubResource("Choice_router_pragmatic")])
metadata/_custom_type_script = "uid://cd45ite7r06rf"
