[gd_resource type="Resource" script_class="JourneyEvent" format=3 uid="uid://sg0evpoolmrc001"]

[ext_resource type="Script" uid="uid://cd45ite7r06rf" path="res://addons/journey_engine_core/journey_event.gd" id="1_event"]
[ext_resource type="Script" uid="uid://bsf1m3b2h1ukg" path="res://addons/journey_engine_core/journey_choice.gd" id="2_choice"]
[ext_resource type="Script" uid="uid://i001tv2xcpdh" path="res://addons/journey_engine_core/journey_consequence.gd" id="3_conseq"]
[ext_resource type="Script" uid="uid://k60namdri10y" path="res://addons/journey_engine_core/journey_condition.gd" id="4_cond"]
[ext_resource type="Script" uid="uid://bwkdyqkiuostq" path="res://addons/journey_engine_core/journey_condition_group.gd" id="5_group"]

[sub_resource type="Resource" id="Conseq_merch_trade_gold"]
script = ExtResource("3_conseq")
operation = 1
key = "gold"
value = 20.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Conseq_merch_trade_rations"]
script = ExtResource("3_conseq")
operation = 0
key = "rations"
value = 30.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Conseq_merch_progress"]
script = ExtResource("3_conseq")
operation = 0
key = "road_progress"
value = 10.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Choice_merch_trade"]
script = ExtResource("2_choice")
button_text = "Trade for rations (-20 gold, +30 rations)."
consequences = Array[ExtResource("3_conseq")]([SubResource("Conseq_merch_trade_gold"), SubResource("Conseq_merch_trade_rations"), SubResource("Conseq_merch_progress")])
continue_to_pool = true
pool_tags_filter = Array[String](["road"])
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[sub_resource type="Resource" id="Cond_merch_helped_stranger"]
script = ExtResource("4_cond")
key = "helped_stranger"
op = 6
metadata/_custom_type_script = "uid://k60namdri10y"

[sub_resource type="Resource" id="Group_merch_helped_stranger"]
script = ExtResource("5_group")
conditions = Array[ExtResource("4_cond")]([SubResource("Cond_merch_helped_stranger")])
metadata/_custom_type_script = "uid://bwkdyqkiuostq"

[sub_resource type="Resource" id="Conseq_merch_recommend_gold"]
script = ExtResource("3_conseq")
operation = 0
key = "gold"
value = 25.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Choice_merch_recommend"]
script = ExtResource("2_choice")
button_text = "\"The stranger I helped sent me.\" (+25 gold)"
visibility = SubResource("Group_merch_helped_stranger")
consequences = Array[ExtResource("3_conseq")]([SubResource("Conseq_merch_recommend_gold"), SubResource("Conseq_merch_progress")])
continue_to_pool = true
pool_tags_filter = Array[String](["road"])
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[sub_resource type="Resource" id="Choice_merch_pass"]
script = ExtResource("2_choice")
button_text = "Wave and travel on."
consequences = Array[ExtResource("3_conseq")]([SubResource("Conseq_merch_progress")])
continue_to_pool = true
pool_tags_filter = Array[String](["road"])
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[resource]
script = ExtResource("1_event")
narrative_text = "A merchant rolls his wagon to a halt and waves you down."
id = &"evt_road_merchant"
pool_eligible = true
event_tags = Array[String](["road", "trade"])
weight = 100
choices = Array[ExtResource("2_choice")]([SubResource("Choice_merch_trade"), SubResource("Choice_merch_recommend"), SubResource("Choice_merch_pass")])
metadata/_custom_type_script = "uid://cd45ite7r06rf"
