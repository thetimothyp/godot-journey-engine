[resource]
script = ExtResource("1_event")
narrative_text = "You crest a rise and see it: the old city, walls pale in the late sun. The road that brought you here ends at its gates."
id = &"evt_road_inn"
event_tags = Array[String](["road"])
weight = 60
pool_conditions = SubResource("Group_inn_progress")
choices = Array[ExtResource("2_choice")]([SubResource("Choice_inn_enter")])
metadata/_custom_type_script = "uid://cd45ite7r06rf"
