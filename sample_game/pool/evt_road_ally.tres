[gd_resource type="Resource" script_class="JourneyEvent" format=3 uid="uid://sg0evpoolall001"]

[ext_resource type="Script" uid="uid://cd45ite7r06rf" path="res://journey_core/journey_event.gd" id="1_event"]
[ext_resource type="Script" uid="uid://bsf1m3b2h1ukg" path="res://journey_core/journey_choice.gd" id="2_choice"]
[ext_resource type="Script" uid="uid://i001tv2xcpdh" path="res://journey_core/journey_consequence.gd" id="3_conseq"]
[ext_resource type="Script" uid="uid://k60namdri10y" path="res://journey_core/journey_condition.gd" id="4_cond"]
[ext_resource type="Script" uid="uid://bwkdyqkiuostq" path="res://journey_core/journey_condition_group.gd" id="5_group"]

[sub_resource type="Resource" id="Cond_ally_helped"]
script = ExtResource("4_cond")
key = "helped_stranger"
op = 6
metadata/_custom_type_script = "uid://k60namdri10y"

[sub_resource type="Resource" id="Group_ally_helped"]
script = ExtResource("5_group")
conditions = Array[ExtResource("4_cond")]([SubResource("Cond_ally_helped")])
metadata/_custom_type_script = "uid://bwkdyqkiuostq"

[sub_resource type="Resource" id="Conseq_ally_gift_gold"]
script = ExtResource("3_conseq")
operation = 0
key = "gold"
value = 30.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Conseq_ally_gift_sanity"]
script = ExtResource("3_conseq")
operation = 0
key = "sanity"
value = 15.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Conseq_ally_progress"]
script = ExtResource("3_conseq")
operation = 0
key = "road_progress"
value = 10.0
metadata/_custom_type_script = "uid://i001tv2xcpdh"

[sub_resource type="Resource" id="Choice_ally_accept"]
script = ExtResource("2_choice")
button_text = "Accept the gift (+30 gold, +15 sanity)."
consequences = Array[ExtResource("3_conseq")]([SubResource("Conseq_ally_gift_gold"), SubResource("Conseq_ally_gift_sanity"), SubResource("Conseq_ally_progress")])
continue_to_pool = true
pool_tags_filter = Array[String](["road"])
metadata/_custom_type_script = "uid://bsf1m3b2h1ukg"

[resource]
script = ExtResource("1_event")
narrative_text = "The stranger you helped catches up on a borrowed horse. \"I owe you,\" they say, and press a small purse into your hand."
id = &"evt_road_ally"
event_tags = Array[String](["road"])
weight = 80
pool_conditions = SubResource("Group_ally_helped")
choices = Array[ExtResource("2_choice")]([SubResource("Choice_ally_accept")])
metadata/_custom_type_script = "uid://cd45ite7r06rf"
